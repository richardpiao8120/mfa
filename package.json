{
  "name": "mfa-root",
  "private": true,
  "scripts": {
    "start": "npm-run-all --parallel start:host start:remoteA start:remoteB start:remoteC",
    "start:host": "cd host && npm start",
    "start:remoteA": "cd remoteA && npm start",
    "start:remoteB": "cd remoteB && npm start",
    "start:remoteC": "cd remoteC && npm start"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
